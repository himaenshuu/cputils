vcpkg_from_github(
    OUT_SOURCE_PATH SOURCE_PATH
    REPO himaenshuu/cputils
    REF "v${VERSION}"
    SHA512 88CF8C617EF597482082305CED879D08106159838A0A68EFA5B2BB529D7371696E35D4F5D4F5AB6F1F84443F787F91ACB8BD3B173ADFE37EC2F367DC93971504
    HEAD_REF main
)
set(VCPKG_BUILD_TYPE release)
vcpkg_cmake_configure(
    SOURCE_PATH "${SOURCE_PATH}"
)
vcpkg_cmake_install()
vcpkg_cmake_config_fixup(CONFIG_PATH lib/cmake/cputils)
file(REMOVE_RECURSE "${CURRENT_PACKAGES_DIR}/debug")
vcpkg_install_copyright(
    FILE_LIST "${SOURCE_PATH}/LICENSE"
)
